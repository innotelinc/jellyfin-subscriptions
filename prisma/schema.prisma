generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SignupStatus {
  started
  checkout_pending
  paid
  pending_approval
  approved
  invited
  activated
  suspended
  cancelled
  rejected
}

enum SubscriptionStatus {
  incomplete
  trialing
  active
  past_due
  unpaid
  canceled
  paused
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  fullName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  signups      Signup[]
}

model Signup {
  id                   String              @id @default(cuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SignupStatus        @default(started)
  desiredUsername      String?
  notes                String?
  approvedAt           DateTime?
  rejectedAt           DateTime?
  approverEmail        String?
  stripeCustomerId     String?             @unique
  stripeCheckoutId     String?             @unique
  stripeSubscriptionId String?             @unique
  subscriptionStatus   SubscriptionStatus?
  currentPeriodEnd     DateTime?
  jfaInviteCode        String?
  jfaInviteUrl         String?
  jellyfinUserId       String?             @unique
  jellyfinUsername     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  events               SignupEvent[]
}

model SignupEvent {
  id        String   @id @default(cuid())
  signupId  String
  signup    Signup   @relation(fields: [signupId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())
}
